{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Riftle Launcher",
  "version": "1.0.0-beta.1",
  "identifier": "com.riftle.launcher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "launcher",
        "title": "Riftle",
        "width": 564,
        "height": 56,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "focus": true
      },
      {
        "label": "settings",
        "title": "Riftle Settings",
        "width": 450,
        "height": 600,
        "minWidth": 450,
        "minHeight": 400,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "visible": false,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}


